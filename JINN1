#!/bin/bash

# ==========================================
#        JINN COMMAND LAUNCHER 
# ==========================================

# Colors
G='\e[1;32m'
R='\e[1;31m'
C='\e[1;36m'
Y='\e[1;33m'
W='\e[0m'

clear
echo -e "${C}==========================================${W}"
echo -e "${G}         JINN COMMAND LAUNCHER            ${W}"
echo -e "${C}==========================================${W}"

echo -e "${C}[*] Checking System Health...${W}"

# --- STEP 1: LOCK & REPO FIX ---
killall apt apt-get 2>/dev/null
rm -f /data/data/com.termux/files/usr/var/lib/dpkg/lock*

echo "deb https://packages.termux.dev/apt/termux-main stable main" > $PREFIX/etc/apt/sources.list

# --- STEP 2: VERSION & MODULE CHECK ---
PY_VER=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null)

if [ "$PY_VER" != "3.13" ]; then
    echo -e "${Y}[!] System Upgrade Required. Fixing Termux...${W}"
    export DEBIAN_FRONTEND=noninteractive
    
    apt-get update -y -q --allow-insecure-repositories
    apt-get install -y -q --allow-unauthenticated termux-keyring
    
    echo -e "${Y}[*] Installing Python 3.13...${W}"
    apt-get update -y -q
    apt-get install -y -q -o Dpkg::Options::="--force-confold" python
    
    echo -e "${Y}[*] Installing required modules for JINN V17...${W}"
    # 🔥 FIX: cryptography removed, only pycryptodome required!
    python3 -m pip install requests rich urllib3 pycryptodome --quiet
    
    echo -e "${G}[✔] System Successfully Upgraded to 3.13 with all modules!${W}"
else
    if ! python3 -c "import requests, rich, urllib3, Cryptodome" &>/dev/null; then
        echo -e "${Y}[!] Modules missing in Python 3.13. Installing now...${W}"
        python3 -m pip install requests rich urllib3 pycryptodome --quiet
    fi
    echo -e "${G}[✔] System is Healthy.${W}"
fi

# --- STEP 3: SMART JINN API APP VERIFICATION & DOWNLOAD ---
CONFIG_PATH="/sdcard/jinn_api_config.json"
SHARED_CONFIG_PATH="$HOME/storage/shared/jinn_api_config.json"

if [ ! -f "$CONFIG_PATH" ] && [ ! -f "$SHARED_CONFIG_PATH" ]; then
    echo -e "\n${C}==========================================${W}"
    echo -e "${Y}      ⚠️  CRITICAL REQUIREMENT ⚠️${W}"
    echo -e "${W}JINN Cloud DRM requires the official Android App.${W}"
    echo -e "${C}==========================================${W}"
    echo -e "${W}Do you have the JINN API v2.0 App installed and activated? (y/n)${W}"
    read -p " ╰─➤ " app_choice
    
    if [[ "$app_choice" == "n" || "$app_choice" == "N" ]]; then
        echo -e "\n${G}[*] Opening GitHub to download the JINN API App...${W}"
        sleep 1
        
        # 🔥 FIX: Syntax error fixed and link updated to GitHub Releases
        GITHUB_URL="https://github.com/Hassan-jinn/Jinn/releases/latest"
        
        if command -v termux-open-url &> /dev/null; then
            termux-open-url "$GITHUB_URL"
        else
            xdg-open "$GITHUB_URL" 2>/dev/null || am start -a android.intent.action.VIEW -d "$GITHUB_URL"
        fi
        
        echo -e "\n${Y}🔥 Next Steps to Follow:${W}"
        echo -e "1. Download and Install the App."
        echo -e "2. Open App -> Tap 'Register Device'."
        echo -e "3. Tap 'Activate Session'."
        echo -e "4. Run this Termux command again.\n"
        exit 1
    fi
else
    echo -e "${G}[✔] DRM Config Found! Authentication Ready.${W}"
fi

# --- STEP 4: SMART LAUNCHER ---
echo -e "${C}[*] Launching JINN Engine...${W}"
sleep 0.5
ARCH=$(uname -m)
if [[ "$ARCH" == "aarch64" ]]; then
    chmod +x JINN64 && ./JINN64 "$@"
elif [[ "$ARCH" == armv* ]] || [[ "$ARCH" == "x86_64" ]] || [[ "$ARCH" == "i686" ]]; then
    chmod +x JINN32 && ./JINN32 "$@"
else
    echo -e "${R}[!] Fatal Error: Unrecognized Architecture ($ARCH)${W}"
fi
