#!/bin/bash

# ==========================================

# Colors
G='\e[1;32m'
R='\e[1;31m'
C='\e[1;36m'
Y='\e[1;33m'
W='\e[0m'

echo -e "${C}[*] JINN V16 Checking System Health...${W}"

# --- STEP 1: PYTHON VERSION CHECK & AUTO-FIX ---
# Python ka version number nikalna
PY_VER=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null)

if [ "$PY_VER" != "3.13" ]; then
    echo -e "${Y}[!] Outdated System Detected. Auto-fixing Termux Repositories...${W}"
    
    # 1. Dead Server hata kar Official Zinda Server lagana
    echo "deb https://packages.termux.dev/apt/termux-main stable main" > $PREFIX/etc/apt/sources.list
    
    # 2. Khamoshi se sab kuch update karna
    echo -e "${Y}[*] Installing Python 3.13 (Please wait, DO NOT CLOSE)...${W}"
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -y -q
    apt-get install -y -q -o Dpkg::Options::="--force-confold" python
    
    # 3. Zaroori modules lagana
    pip install requests pycryptodome rich -q
    
    echo -e "${G}[✔] System Successfully Upgraded to Python 3.13!${W}"
else
    echo -e "${G}[✔] Python System is Perfect.${W}"
fi

# --- STEP 2: SMART LAUNCHER ---
ARCH=$(uname -m)
echo -e "${C}[*] Booting Engine for: $ARCH${W}"

if [[ "$ARCH" == "aarch64" ]]; then
    chmod +x JINN64
    ./JINN64 "$@"
elif [[ "$ARCH" == armv* ]] || [[ "$ARCH" == "x86_64" ]] || [[ "$ARCH" == "i686" ]]; then
    chmod +x JINN32
    ./JINN32 "$@"
else
    echo -e "${R}[!] Fatal Error: Unrecognized Architecture ($ARCH)${W}"
fi
